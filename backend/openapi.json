{
  "openapi": "3.0.0",
  "info": {
    "title": "Password Generator API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/api/generate": {
      "post": {
        "summary": "Генерация пароля",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "length": { "type": "integer", "example": 12 },
                  "useUpper": { "type": "boolean", "example": true },
                  "useLower": { "type": "boolean", "example": true },
                  "useDigits": { "type": "boolean", "example": true },
                  "useSpecial": { "type": "boolean", "example": false },
                  "excludeAmbiguous": { "type": "boolean", "example": false }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "password": { "type": "string" },
                    "history": { "type": "array" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/history": {
      "get": {
        "summary": "Получить историю паролей",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Очистить историю",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/check-strength": {
      "post": {
        "summary": "Проверить сложность пароля",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": { "type": "string", "example": "myPassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}